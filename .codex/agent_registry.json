      "allowed_actions": ["run_tests", "report"],
      "workspace": ".codex/worktrees/tester"
    },
    {
      "name": "Documenter",
      "role": "Maintain runbooks, release notes, and usage docs",
      "skills": ["documentation", "summarization", "change_tracking"],
      "allowed_actions": ["document", "summarize"],
      "workspace": ".codex/worktrees/documenter"
    }
