{
  "agents": [
    {
      "name": "Planner",
      "role": "Break goals into executable task plans",
      "skills": ["planning", "task_decomposition", "risk_assessment"],
      "allowed_actions": ["plan", "document"],
      "workspace": ".codex/worktrees/planner"
    },
    {
      "name": "Coder",
      "role": "Implement code changes from accepted plans",
